---
const { title = 'Gamet Studios Dashboard', description = 'Ein Dashbord für Gamet Studios' } = Astro.props;

import ServerDropdown from '../components/ServerDropdown.astro';
import UserDropdown from '../components/UserDropdown.astro';
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <meta name="description" content={description}>
    
    <!-- Favicon / Browser Tab Logo -->
    <link rel="icon" type="image/png" href="/gs_pb_icon_black.png">
    <link rel="apple-touch-icon" href="/gs_pb_icon_black.png">
    
    <link rel="stylesheet" href="/styles/global.css">
    <link rel="stylesheet" href="/styles/components/user-dropdown.css">
    <link rel="stylesheet" href="/styles/components/server-dropdown.css">
</head>
<body class="bg-[#0f172a] text-slate-200 flex min-h-screen">

    <!-- Sidebar -->
    <aside class="w-72 bg-[#1e2937] border-r border-slate-700 flex-shrink-0">
        <div class="p-6 border-b border-slate-700">
            <div class="flex items-center gap-3">
                <!-- Logo mit schönerem Styling -->
                <div class="logo-container">
                    <img 
                        src="/gs_pb_icon_black.png" 
                        alt="Gamestudios Logo" 
                        class="logo"
                    >
                </div>
                
                <div>
                    <div class="font-bold text-xl tracking-tight">Gamet Studios</div>
                </div>
            </div>
        </div>

        <!-- Rest bleibt gleich -->
        <div class="p-6">
            <ServerDropdown />
        </div>

        <nav class="px-3 space-y-1">
            <a href="/" class="nav-item">🏠 Dashboard</a>
            <a href="/modules" class="nav-item">📦 Module</a>
            <a href="/settings" class="nav-item">⚙️ Einstellungen</a>
            <a href="/billing" class="nav-item">💰 Rechnungen</a>
            <a href="/impressum" class="nav-item">🔨 Impressum</a>

            <footer class="absolute bottom-0 w-full p-4 text-center text-sm text-slate-500">
                &copy; {new Date().getFullYear()} Gamet Studios. Alle Rechte vorbehalten.
                <UserDropdown />
            </footer>
        </nav>
    </aside>

    <!-- ... Rest unverändert ... -->
    <div class="flex-1 flex flex-col">
        <header class="h-16 bg-[#1e2937] border-b border-slate-700 flex items-center justify-between px-8">
            <h1 class="text-2xl font-semibold">{title}</h1>
        </header>

        <main class="flex-1 p-8 overflow-auto">
            <slot />
        </main>
    </div>

    <script src="/scripts/main.js" type="module"></script>
</body>
</html>