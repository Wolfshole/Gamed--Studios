---
const { username = "Gast", avatar = "https://via.placeholder.com/128" } = Astro.props;
---

<div class="relative" id="user-dropdown">
  <button id="user-button" class="user-dropdown-button">
    <img src={avatar} alt="Avatar" class="avatar">
    <div class="user-info hidden sm:block">
      <span class="username">{username}</span>
    </div>
    <svg xmlns="http://www.w3.org/2000/svg" class="chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
    </svg>
  </button>

  <div id="user-menu" class="user-menu hidden">
    <a href="/settings" class="dropdown-item">⚙️ Einstellungen</a>
    <a href="/billing" class="dropdown-item">💰 Rechnungsdaten</a>
    <div class="divider"></div>
    <button onclick="handleLogout()" class="dropdown-item logout">⬅️ Abmelden</button>
  </div>
</div>

<link rel="stylesheet" href="/styles/components/user-dropdown.css">
<script src="/scripts/user-dropdown.js" type="module"></script>